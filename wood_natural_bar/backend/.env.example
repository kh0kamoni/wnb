# ============================================================
# Wood Natural Bar - Backend Environment Configuration
# ============================================================

# Server
APP_NAME="Wood Natural Bar"
APP_VERSION="1.0.0"
DEBUG=true
HOST=0.0.0.0
PORT=8000

# Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql://woodbar:woodbar_pass@localhost:5432/woodbar_db

# File Storage (local paths)
UPLOAD_DIR=./uploads
STATIC_DIR=./static
MAX_UPLOAD_SIZE=10485760

# Printing
DEFAULT_RECEIPT_PRINTER_IP=192.168.1.100
DEFAULT_RECEIPT_PRINTER_PORT=9100
DEFAULT_KITCHEN_PRINTER_IP=192.168.1.101
DEFAULT_KITCHEN_PRINTER_PORT=9100
DEFAULT_BAR_PRINTER_IP=192.168.1.102
DEFAULT_BAR_PRINTER_PORT=9100

# Restaurant Branding (customizable)
RESTAURANT_NAME="Wood Natural Bar"
RESTAURANT_TAGLINE="Fresh & Natural"
RESTAURANT_ADDRESS="123 Main Street, City"
RESTAURANT_PHONE="+1 234 567 890"
RESTAURANT_CURRENCY="USD"
RESTAURANT_CURRENCY_SYMBOL="$"
RESTAURANT_TIMEZONE="America/New_York"
RESTAURANT_TAX_RATE=0.10
RESTAURANT_SERVICE_CHARGE=0.05

# mDNS
MDNS_HOSTNAME=woodbar-server
